{
  "name": "puiux-pilot",
  "version": "0.1.0",
  "description": "Adaptive AI coding assistant configurator for Claude Code. One command to scan, configure, and optimize any project.",
  "type": "module",
  "bin": {
    "puiux-pilot": "./bin/puiux-pilot.mjs"
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "src/hooks/",
    "src/skills/",
    "templates/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "ai-coding",
    "hooks",
    "developer-tools",
    "project-intelligence",
    "config-translation",
    "quality-scoring",
    "puiux"
  ],
  "author": "PUIUX <welcome@puiux.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/PUIUX-Cloud/puiux-pilot"
  },
  "homepage": "https://github.com/PUIUX-Cloud/puiux-pilot#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "fast-glob": "^3.3.3",
    "diff": "^7.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.4.0",
    "vitest": "^4.0.18",
    "@types/node": "^25.3.3",
    "@types/diff": "^7.0.0"
  }
}
